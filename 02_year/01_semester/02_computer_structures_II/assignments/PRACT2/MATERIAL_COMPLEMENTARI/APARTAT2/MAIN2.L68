000013BE  51CA FFEE                722              DBRA.W  D2,.LOOP                
000013C2                           723  ; ----------------------FINAL BUCLE RECORREGUT BOTONS--------------------------
000013C2  4CDF 0104                724  .FINAL     MOVEM.L (A7)+,A0/D2             ;RESTAURAM REGISTRES
000013C6  4E75                     725              RTS
000013C8                           726  
000013C8                           727  
000013C8                           728  ; -----------------------------------------------------------------------------
000013C8                           729  BTLPLOT
000013C8                           730  ; CALLS BTNPLOT FOR ALL THE BUTTONS IN THE BUTTON LIST.
000013C8                           731  ; INPUT    : NONE
000013C8                           732  ; OUTPUT   : NONE
000013C8                           733  ; MODIFIES : NONE
