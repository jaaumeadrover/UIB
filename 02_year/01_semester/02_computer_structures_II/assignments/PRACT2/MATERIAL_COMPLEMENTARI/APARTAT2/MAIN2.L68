00001214                           441              INCLUDE "BUTTON.X68"            ; BUTTON MANAGEMENT
00001214                           442  ; =============================================================================
00001214                           443  ; TITLE    : BUTTON MANAGEMENT
00001214                           444  ; AUTHOR   : ANTONI BURGUERA
00001214                           445  ; HISTORY  : 05-JULY-2021 - CREATION
00001214                           446  ; COMMENTS : * A BUTTON IS DEFINED BY A STATIC DATA BLOCK (SDB), WHICH DOES NOT
00001214                           447  ;              CHANGE OVER TIME, AND A VARIABLE DATA BLOCK (VDB), THAT CAN
00001214                           448  ;              CHANGE OVER TIME. CHANGES IN THE VDB ARE PRODUCED WHEN CALLING
00001214                           449  ;              SUBROUTINE BTNUPD.
00001214                           450  ;
00001214                           451  ;            * THE BUTTON SDB (CAN BE IN ROM) HAS THE FOLLOWING FIELDS. THE
00001214                           452  ;              NUMBER DENOTES THE OFFSET WITH RESPECT TO THE SDB START:
00001214                           453  ;
00001214                           454  ;                +0  - WORD - YTOP COORDINATE (PIXELS)
00001214                           455  ;                +2  - WORD - XLEFT COORDINATE (PIXELS)
00001214                           456  ;                +4  - WORD - HEIGHT (PIXELS)
00001214                           457  ;                +6  - WORD - WIDTH (PIXELS)
00001214                           458  ;                +8  - LONG - CALLBACK POINTER
00001214                           459  ;                +12 - BYTE STRING - ZERO TERMINATED STRING. TEXT TO SHOW.
00001214                           460  ;
00001214                           461  ;            * THE BUTTON VDB (MUST BE IN RAM) IS:
00001214                           462  ;
00001214                           463  ;                +0 - LONG - POINTER TO THE STATIC DATABLOCK
00001214                           464  ;                +4 - BYTE - STATUS WITH FORMAT XXXXXCPI WHERE:
00001214                           465  ;                            - I (BIT 0) - 1=MOUSE INSIDE, 0=MOUSE OUTSIDE
00001214                           466  ;                            - P (BIT 1) - 1=MOUSE PRESSED INSIDE
00001214                           467  ;                                          0=MOUSE NOT PRESSED INSIDE
00001214                           468  ;                            - C (BIT 2) - 1=MOUSE CLICKED INSIDE
00001214                           469  ;                                          0=MOUSE NOT CLICKED INSIDE
00001214                           470  ;                            NOTE THAT IF I=0 THEN P=C=0, IF I=1 AND P=0
00001214                           471  ;                            THEN C=0.
00001214                           472  ; =============================================================================
00001214                           473  
00001214                           474  ; -----------------------------------------------------------------------------
00001214                           475  BTNINIT
00001214                           476  ; INITIALIZES THE BUTTON BY:
00001214                           477  ;  * COPYING THE SDB POINTER INTO THE VDB.
00001214                           478  ;  * CLEARING THE STATUS BYTE.
00001214                           479  ; INPUT    : A0 - POINTER TO THE VARIABLE DATABLOCK
00001214                           480  ;            A1 - POINTER TO THE STATIC DATABLOCK
00001214                           481  ; OUTPUT   : NONE
00001214                           482  ; MODIFIES : NONE
00001214                           483  ; -----------------------------------------------------------------------------
00001214                           484  
00001214                           485  ; TODO : PLACE YOUR CODE HERE
00001214  2089                     486              MOVE.L  A1, (A0) ;FICAM EL SDB A VDB
00001216  4228 0004                487              CLR.B   4(A0)    ;CLEAR STATUS BYTE
0000121A  4E75                     488              RTS
0000121C                           489              
0000121C                           490  ; -----------------------------------------------------------------------------
0000121C                           491  BTNUPD
0000121C                           492  ; UPDATES THE BUTTON VDB AND EXECUTES THE CALLBACK IF REQUIRED
0000121C                           493  ; INPUT    : A0 - POINTER TO THE VARIABLE DATABLOCK
0000121C                           494  ; OUTPUT   : NONE
0000121C                           495  ; MODIFIES : NONE
0000121C                           496  ; -----------------------------------------------------------------------------
0000121C                           497  
0000121C                           498  ; TODO : PLACE YOUR CODE HERE
0000121C  48E7 E040                499              MOVEM.L D0-D2/A1, -(A7)
00001220  2250                     500              MOVE.L  (A0), A1                ;OBTENIM EL SDB DEL VDB
00001222  3029 0002                501              MOVE.W  2(A1), D0               ;OBTENIM XLEFT DE SDB
00001226  3229 0006                502              MOVE.W  6(A1), D1               ;OBTENIM EL WIDTH DE SDB
0000122A  B079 000014EE            503              CMP.W   (MOUX), D0              ;COMPROVAM EL COMENÇAMENT DEL BOTO X
00001230  6E00 0072                504              BGT     .NO                     ;NO DINS BOTO
00001234  D240                     505              ADD.W   D0, D1                  ;AMPLADA DEL BOTO
00001236  B279 000014EE            506              CMP.W   (MOUX), D1              ;COMPROVAM EL FINAL DEL BOTO X
0000123C  6D00 0066                507              BLT     .NO                     ;NO DINS BOTO
00001240  3011                     508              MOVE.W  (A1), D0                ;UPPERY
00001242  3229 0004                509              MOVE.W  4(A1), D1               ;HEIGHT
00001246  B079 000014EC            510              CMP.W   (MOUY), D0              ;COMPROVAM EL COMENÇAMENT DEL BOTO Y
0000124C  6E00 0056                511              BGT     .NO                     ;NO DINS BOTO
00001250  D240                     512              ADD.W  D0, D1                   ;ALTURA BOTO
00001252  B279 000014EC            513              CMP.W   (MOUY), D1              ;COMPROVAM EL FINAL DEL BOTO Y
00001258  6D00 004A                514              BLT     .NO                     ;NO DINS BOTO
0000125C  1028 0004                515              MOVE.B  4(A0), D0               ;OBTENIM L'STATUS BYTE
00001260                           516              
00001260                           517              ;COMPROVAM EL VALOR DEL BIT I I EL MODIFICAM
00001260  0000 0001                518              ORI.B   #$01, D0                ;POSAP I A 1  
00001264                           519           
00001264                           520              ;COMPROVAM EL VALOR DEL BIT P I EL MODIFICAM
00001264  1239 000014F0            521              MOVE.B  (MOUVAL), D1            ;OBTENIM EL VALOR ACTUAL DEL MOUSE
0000126A  0801 0000                522              BTST.L  #0, D1                  ;MIRAM SI S'HA PITJAT EL BOTO ESQUERRA
0000126E  6700 000A                523              BEQ     .CLRP                   ;NO PTJAT
00001272  0040 0002                524              ORI.W   #$02, D0                ;POSAM P A 1
00001276  6000 0006                525              BRA     .CHECKC    
0000127A  0200 000D                526  .CLRP       ANDI.B  #$0D, D0                ;CLEAR DE P
0000127E                           527  .CHECKC
0000127E                           528  
0000127E                           529              ;COMPROVAM EL VALOR DEL BIT C I EL MODIFICAM
