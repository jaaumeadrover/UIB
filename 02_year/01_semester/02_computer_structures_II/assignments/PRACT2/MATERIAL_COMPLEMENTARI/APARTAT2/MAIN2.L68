00001284  0801 0000                531              BTST.L  #0, D1                  ;CLICAT?
00001288  6700 0012                532              BEQ     .CLEARC
0000128C  0040 0004                533              ORI.W   #$04, D0                ;POSAM C A 1
00001290  2429 0008                534              MOVE.L  8(A1), D2               ;OBTENIM EL CALLBACK
00001294  2242                     535              MOVE.L  D2, A1
00001296  4E91                     536              JSR     (A1)                    ;JSR CAP A LA DIRECCIO DEL CALLBACK
00001298  6000 0006                537              BRA     .SETC
0000129C  0200 000B                538  .CLEARC     ANDI.B  #$0B, D0                ;CLEAR DE C    
000012A0                           539  .SETC
000012A0  6000 000A                540              BRA     .END                  
000012A4  1028 0004                541  .NO         MOVE.B  4(A0), D0               ;OBTENIM L'STATUS BYTE
000012A8  0200 0000                542              ANDI.B  #$00, D0                ;CLEAR DE C P I 
000012AC  1140 0004                543  .END        MOVE.B  D0, 4(A0)
000012B0  4CDF 0207                544              MOVEM.L (A7)+, D0-D2/A1
000012B4  4E75                     545              RTS
