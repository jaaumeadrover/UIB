00001294  2242                     535              MOVE.L  D2, A1
00001296  4E91                     536              JSR     (A1)                    ;JSR CAP A LA DIRECCIO DEL CALLBACK
00001298  6000 0006                537              BRA     .SETC
0000129C  0200 000B                538  .CLEARC     ANDI.B  #$0B, D0                ;CLEAR DE C    
000012A0                           539  .SETC
000012A0  6000 000A                540              BRA     .END                  
