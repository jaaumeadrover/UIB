000012A8  0200 0000                542              ANDI.B  #$00, D0                ;CLEAR DE C P I 
000012AC  1140 0004                543  .END        MOVE.B  D0, 4(A0)
000012B0  4CDF 0207                544              MOVEM.L (A7)+, D0-D2/A1
000012B4  4E75                     545              RTS
