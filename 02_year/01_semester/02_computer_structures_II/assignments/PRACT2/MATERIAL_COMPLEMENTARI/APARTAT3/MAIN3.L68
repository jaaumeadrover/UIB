000014B6                           870  
000014B6                           871  
000014B6                           872  
000014B6                           873  ; -----------------------------------------------------------------------------
000014B6                           874  GRDRUPD
000014B6                           875  ; UPDATES THE GRID ACCORDING TO 2-PLAYER GAME OF LIFE RULES AS FOLLOWS:
000014B6                           876  ; * ADDS 1 TO THE NUMBER OF GENERATIONS (GRDNGEN)
000014B6                           877  ; * SWITCHES THE MATRIX POINTERS (GRDDST AND GRDSRC).
000014B6                           878  ; * CHECKS THE NEIGHBORS USING THE NEW SOURCE MATRIX (POINTER BY GRDDRC)
000014B6                           879  ; * THE RESULTS OF APPLYING THE RULES ARE WRITTEN INTO THE NEW DESTINATION
000014B6                           880  ;   MATRIX (POINTED BY GRDDST).
000014B6                           881  ; * THE RULES ARE THE FOLLOWING, WHERE P1 AND P2 ARE 1 AND 2 RESPECTIVELY,
000014B6                           882  ;   DEAD CELLS ARE REPRESENTED BY 0 AND NP1 AND NP2 DENOTE THE NUMBER OF
000014B6                           883  ;   PLAYER 1 AND PLAYER 2 NEIGHBORS RESPECTIVELY:
000014B6                           884  ;   + SURVIVAL RULES
000014B6                           885  ;     - IF CELL IS P1 AND NP1-NP2 IS 2 OR 3 -> NEW VALUE IS P1
000014B6                           886  ;     - IF CELL IS P1 AND NP1-NP2 IS 1 AND NP1>=2 -> NEW VALUE IS P1
000014B6                           887  ;     - OTHERWISE -> NEW VALUE IS 0
000014B6                           888  ;     - IF CELL IS P2 AND NP2-NP1 IS 2 OR 3 -> NEW VALUE IS P2
000014B6                           889  ;     - IF CELL IS P2 AND NP2-NP1 IS 1 AND NP2>=2 -> NEW VALUE IS P2
000014B6                           890  ;     - OTHERWISE -> NEW VALUE IS 0
000014B6                           891  ;   + BIRTH RULES
000014B6                           892  ;     - THE CELL HAS EXACTLY THREE P1 NEIGHBOURS AND THE NUMBER
000014B6                           893  ;       OF P2 NEIGHBOURS IS DIFFERENT FROM THREE. IN THIS CASE A
000014B6                           894  ;       P1 TOKEN IS BORN IN THE CELL.
000014B6                           895  ;     - THE CELL HAS EXACTLY THREE P2 NEIGHBOURS AND THE NUMBER
000014B6                           896  ;       OF P1 NEIGHBOURS IS DIFFERENT FROM THREE. IN THIS CASE A
000014B6                           897  ;       P2 TOKEN IS BORN IN THE CELL.
000014B6                           898  ;     - THE CELL HAS EXACTLY THREE WHITE AND THREE BLACK NEIGHBOURS.
000014B6                           899  ;       IN THIS CASE AN UNBIASED COIN DETERMINES WHETHER A WHITE OR
000014B6                           900  ;       BLACK TOKEN IS BORN IN THE CELL.
000014B6                           901  ; INPUT    : NONE
000014B6                           902  ; OUTPUT   : NONE
000014B6                           903  ; MODIFIES : NONE
000014B6                           904  ; -----------------------------------------------------------------------------
000014B6                           905  
000014B6                           906  ; TODO : PLACE YOUR CODE HERE
000014B6                           907  
000014B6                           908  
000014B6                           909  ; -----------------------------------------------------------------------------
000014B6                           910  GRDSAVE
000014B6                           911  ; SAVES THE GRID INTO A FILE IN CSV FORMAT
000014B6                           912  ; INPUT    : NONE
000014B6                           913  ; OUTPUT   : NONE
000014B6                           914  ; MODIFIES : NONE
000014B6                           915  ; NOTE     : THE LOCAL BUFFER SIZE MUST BE MAX(512,2*GRDWIDTH+1). PLEASE CHANGE
000014B6                           916  ;            IT ACCORDINGLY IF GRDWIDTH*2+1 IS LARGER THAN 512.
000014B6                           917  ; -----------------------------------------------------------------------------
000014B6  48E7 FFFE                918              MOVEM.L D0-D7/A0-A6,-(A7)       ; TO BE OPTIMIZED
000014BA  103C 0032                919              MOVE.B  #50,D0                  ; CLOSE ALL FILES (RECOMMENDED)
000014BE  4E4F                     920              TRAP    #15
000014C0  9FFC 00000200            921              SUB.L   #512,A7                 ; ROW BUFFER IN LOCAL MEMORY
000014C6  103C 003A                922              MOVE.B  #58,D0                  ; SHOW FILE DIALOG TASK
000014CA  7201                     923              MOVE.L  #1,D1                   ; DISPLAY SAVE DIALOG
000014CC  43F9 00001542            924              LEA     .MSG,A1                 ; STANDARD MESSAGE
000014D2  45F9 0000155C            925              LEA     .FILTER,A2              ; NO FILTER
000014D8  264F                     926              MOVE.L  A7,A3                   ; FILE NAME BUFFER
000014DA  4253                     927              CLR.W   (A3)                    ; ENSURE THERE IS NO STRING
000014DC  4E4F                     928              TRAP    #15
000014DE  4A01                     929              TST.B   D1
000014E0  6700 0054                930              BEQ     .END                    ; IF CANCELLED, DO NOTHING
000014E4  224B                     931              MOVE.L  A3,A1                   ; PLACE THE FILENAME INTO A1
000014E6  103C 0034                932              MOVE.B  #52,D0                  ; CREATE NEW FILE
000014EA  4E4F                     933              TRAP    #15
000014EC  4A40                     934              TST.W   D0                      ; CHECK CREATION ERROR
000014EE  6600 0046                935              BNE     .END                    ; DO NOTHING MORE IF ERROR
000014F2  2C4F                     936              MOVE.L  A7,A6                   ; PUT A6 INTO START OF BUFFER
000014F4  224F                     937              MOVE.L  A7,A1                   ; PUT A1 INTO START OF BUFFER
000014F6  2079 00001A64            938              MOVE.L  (GRDDST), A0            ; A0: POINTER TO THE DATA TO WRITE
000014FC  363C 001F                939              MOVE.W  #GRDHEIGH-1,D3          ; D3: NUMBER OF ROWS - 1
00001500  343C 003F                940  .LOOPY      MOVE.W  #GRDWIDTH-1,D2          ; D2: NUMBER OF COLUMNS - 1
00001504  103C 0030                941  .LOOP       MOVE.B  #'0',D0                 ; ADD CHAR '0' AND THE CELL VALUE
00001508  D018                     942              ADD.B   (A0)+,D0
0000150A  1CC0                     943              MOVE.B  D0, (A6)+               ; STORE IT IN THE BUFFER
0000150C  1CFC 002C                944              MOVE.B  #',',(A6)+              ; NOW PUT THE COMMA
00001510  51CA FFF2                945              DBRA.W  D2,.LOOP
00001514  1D7C 000D FFFF           946              MOVE.B  #$0D,-1(A6)             ; STORE CARRIAGE RETURN (REMOVE ',')
0000151A  1CBC 000A                947              MOVE.B  #$0A,(A6)               ; STORE LINE FEED
0000151E  103C 0036                948              MOVE.B  #54,D0                  ; WRITE TO FILE TASK NUMBER
00001522  243C 00000081            949              MOVE.L  #GRDWIDTH*2+1,D2        ; NUMBER OF BYTES TO WRITE
00001528  4E4F                     950              TRAP    #15                     ; WRITE (A1 IS ALREADY THERE)
0000152A  2C49                     951              MOVE.L  A1,A6                   ; GO BACK TO THE BUFFER START
0000152C  51CB FFD2                952              DBRA.W  D3,.LOOPY
00001530  103C 0038                953              MOVE.B  #56,D0                  ; CLOSE FILE
00001534  4E4F                     954              TRAP    #15
00001536  DFFC 00000200            955  .END        ADD.L   #512,A7                 ; RESTORE STACK
0000153C  4CDF 7FFF                956              MOVEM.L (A7)+,D0-D7/A0-A6       ; TO BE OPTIMIZED
00001540  4E75                     957              RTS
