00001356                           626              INCLUDE "BTNLIST.X68"           ; BUTTON LIST MANAGEMENT
00001356                           627  ; =============================================================================
00001356                           628  ; TITLE    : BUTTON LIST MANAGEMENT
00001356                           629  ; AUTHOR   : ANTONI BURGUERA
00001356                           630  ; HISTORY  : 05-JULY-2021 - CREATION
00001356                           631  ; COMMENTS : * ALLOWS ADDING, UPDATING AND PLOTTING A LIST OF BUTTONS. ALLOWS
00001356                           632  ;              REMOVING THEM ALL, BUT NOT INDIVIDUALLY.
00001356                           633  ;
00001356                           634  ;            * THE LIST OF BUTTONS IS STORED AS A LIST OF BUTTON'S VDB. THIS
00001356                           635  ;              LIST IS STORED AT BTLDATA.
00001356                           636  ;
00001356                           637  ;            * THE LIST OF VBD IS BUILT ASSUMING A MAXIMUM OF BTLMXVDB BUTTONS
00001356                           638  ;              AND A SIZE OF BTNSZVDB BYTES FOR EACH VDB.
00001356                           639  ; =============================================================================
00001356                           640  
00001356                           641  ; -----------------------------------------------------------------------------
00001356                           642  BTLINIT
00001356                           643  ; INITIALIZES BUTTON LIST BY SETTING ALL THE POINTERS TO STATIC DATA BLOCKS
00001356                           644  ; TO $FFFFFFFF.
00001356                           645  ; INPUT    : NONE
00001356                           646  ; OUTPUT   : NONE
00001356                           647  ; MODIFIES : NONE
00001356                           648  ; -----------------------------------------------------------------------------
00001356  48E7 2080                649              MOVEM.L D2/A0,-(A7)             ;GUARDAM REGISTRE CONTADOR I PUNTER
0000135A                           650              
0000135A  41F9 00001A24            651              LEA     BTLDATA,A0              ;APUNTAM A LA LLISTA DE BUTONS
00001360  343C 0009                652              MOVE.W  #BTLMXVDB-1,D2          ;GUARDAM NOMBRE DE ITERACIONS
00001364  20BC FFFFFFFF            653  .LOOP       MOVE.L  #$FFFFFFFF,(A0)         ;ASSIGNAM VALOR BUIT AL BOTÓ
0000136A  5C88                     654              ADD.L   #BTNSZVDB,A0            ;AVANÇAM A LA SEGÜENT POSICIÓ
0000136C  51CA FFF6                655              DBRA.W  D2,.LOOP                
00001370                           656              
00001370  4CDF 0104                657              MOVEM.L (A7)+,D2/A0             ;RESTAURAM REGISTRES
00001374  4E75                     658              RTS
00001376                           659  
00001376                           660  ; -----------------------------------------------------------------------------
00001376  =00001356                661  BTLCLEAR    EQU     BTLINIT
00001376                           662  ; CLEARS THE BUTTON LIST. SAME AS BTLINIT.
00001376                           663  ; INPUT    : NONE
00001376                           664  ; OUTPUT   : NONE
00001376                           665  ; MODIFIES : NONE
00001376                           666  ; -----------------------------------------------------------------------------
00001376                           667  
00001376                           668  ; -----------------------------------------------------------------------------
00001376                           669  BTLADD
00001376                           670  ; ADDS A NEW BUTTON INTO THE BUTTON LIST AND INITS IT.
00001376                           671  ; INPUT    : A1 - POINTER TO THE BUTTON SDB
00001376                           672  ; OUTPUT   : NONE
00001376                           673  ; MODIFIES : NONE
00001376                           674  ; -----------------------------------------------------------------------------
00001376                           675  
00001376                           676              
00001376                           677  ; ----------------------CERCA DEL PRIMER ELEMENT BUIT--------------------------
00001376  48E7 2080                678              MOVEM.L A0/D2,-(A7)             ;GUARDAM REGISTRES
0000137A                           679  
0000137A                           680  
0000137A  41F9 00001A24            681              LEA     BTLDATA,A0              ;APUNTAM A LA LLISTA DE BUTONS
00001380  343C 0009                682              MOVE.W  #BTLMXVDB-1,D2          ;ASSIGNAM NOMBRE DE ITERACIONS A D2
00001384  0C90 FFFFFFFF            683  .LOOP       CMP.L   #$FFFFFFFF,(A0)         ;MIRAM SI EL BOTÓ ESTŔ 'BUIT'
0000138A  6700 000E                684              BEQ     .TROBAT                 ;SI TROBAT, INIT DEL BOTO
0000138E  5C88                     685              ADD.L   #BTNSZVDB,A0            ;AVANÇAM POSICIÓ
00001390  51CA FFF2                686              DBRA.W  D2,.LOOP
00001394                           687  
00001394                           688  ; ----------------------BOTÓ AFEGIT CORRECTAMENT-------------------------------
00001394                           689  
