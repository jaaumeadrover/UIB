000013F0                           755              INCLUDE "GRID.X68"              ; GRID MANAGEMENT
000013F0                           756  ; =============================================================================
000013F0                           757  ; TITLE    : GRID MANAGEMENT
000013F0                           758  ; AUTHOR   : ANTONI BURGUERA
000013F0                           759  ; HISTORY  : 05-JULY-2021 - CREATION
000013F0                           760  ; COMMENTS : * THERE ARE TWO MATRICES (GRDMATR0 AND GRDMATR1) AND TWO POINTERS
000013F0                           761  ;              TO THESE MATRICES (GRDSRC AND GRDDST).
000013F0                           762  ;
000013F0                           763  ;            * THE MATRIX TO BE PLOTTED IS ALWAYS THE ONE POINTED BY GRDDST.
000013F0                           764  ;
000013F0                           765  ;            * THE MATRIX TO BE UPDATED BY THE MOUSE (GRDMUPD) IS ALWAYS THE
000013F0                           766  ;              ONE POINTED BY GRDDST.
000013F0                           767  ;
000013F0                           768  ;            * THE RULES-UPDATE (GRDRUPD) SWITCHES THE POINTERS AND THEN READS
000013F0                           769  ;              THE NEW SOURCE MATRIX (GRDSRC) TO DETERMINE THE NUMBER OF
000013F0                           770  ;              NEIGHBORS. THE RESULTING CELL VALUE IS WRITTEN TO THE DESTINA-
000013F0                           771  ;              TION MATRIX, POINTED BY GRDDST.
000013F0                           772  ; =============================================================================
000013F0                           773  
000013F0                           774  ; -----------------------------------------------------------------------------
000013F0                           775  GRDINIT
000013F0                           776  ; INITIALIZE THE GRID AS FOLLOWS:
000013F0                           777  ; * POINTS THE SOURCE GRID POINTER TO GRDMATR0.
000013F0                           778  ; * POINTS THE DESTINATION GRID POINTER TO GRDMATR1.
000013F0                           779  ; * RESETS THE COUNTERS (GRDNPLR1, GRDNPLR2, GRDNGEN).
000013F0                           780  ; * FILLS THE TWO MATRICES (GRDMATR0 AND GRDMATR1) WITH ZEROS.
000013F0                           781  ; INPUT    : NONE
000013F0                           782  ; OUTPUT   : NONE
000013F0                           783  ; MODIFIES : NONE
000013F0                           784  ; -----------------------------------------------------------------------------
000013F0  48E7 8080                785              MOVEM.L A0/D0,-(A7)
000013F4  23FC 00001A68 00001A60   786              MOVE.L  #GRDMATR0,(GRDSRC)
000013FE  23FC 00002268 00001A64   787              MOVE.L  #GRDMATR1,(GRDDST)
00001408  4279 00002A68            788              CLR.W   (GRDNPLR1)
0000140E  4279 00002A6A            789              CLR.W   (GRDNPLR2)
00001414  4279 00002A6C            790              CLR.W   (GRDNGEN)
0000141A  41F9 00001A68            791              LEA     GRDMATR0,A0
00001420  303C 0FFF                792              MOVE.W  #GRDWIDTH*GRDHEIGH*2-1,D0
00001424  4218                     793  .LOOP       CLR.B   (A0)+
00001426  51C8 FFFC                794              DBRA.W  D0,.LOOP
0000142A  4CDF 0101                795              MOVEM.L (A7)+,A0/D0
0000142E  4E75                     796              RTS
00001430                           797  
00001430                           798  ; -----------------------------------------------------------------------------
00001430                           799  GRDMUPD
00001430                           800  ; GRID UPDATE USING MOUSE. THE INTERFACE IS AS FOLLOWS:
00001430                           801  ; * IF MOUSE IS NOT PRESSED OR IS OUTSIDE THE PLOTTED GRID, DOES NOTHING.
00001430                           802  ; * IF LEFT MOUSE BUTTON IS PRESSED INSIDE THE GRID:
00001430                           803  ;   - A PLAYER 1 (VALUE=1) CELL IS CREATED AT THE MOUSE POSITION IF THE MOUSE
00001430                           804  ;     IS ON THE LEFT HALF OF THE GRID.
00001430                           805  ;   - A PLAYER 2 (VALUE=2) CELL IS CREATED AT THE MOUSE POSITION IF THE MOUSE
00001430                           806  ;     IS ON THE RIGHT HALF OF THE GRID.
00001430                           807  ; * IF RIGHT MOUSE BUTTON IS PRESSED INSIDE THE GRID, THE CELL WHERE THE MOUSE
00001430                           808  ;   IS IS CLEARED (VALUE=0).
00001430                           809  ; INPUT    : NONE
00001430                           810  ; OUTPUT   : NONE
00001430                           811  ; MODIFIES : NONE
00001430                           812  ; -----------------------------------------------------------------------------
00001430                           813  
00001430                           814  ; TODO : PLACE YOUR CODE HERE
00001430                           815  
00001430                           816              ;DO=NOMBRE ITERACIONES MATRIZ
00001430                           817              ;D1=COLUMNA
00001430                           818              ;D2=FILA
00001430                           819              ;D3=MOUVAL
00001430                           820              ;D4=VALUE
00001430                           821  
00001430  48E7 F880                822              MOVEM.L D0-D4/A0,-(A7)
00001434  4280                     823              CLR.L   D0
00001436  4281                     824              CLR.L   D1
00001438  4282                     825              CLR.L   D2
0000143A  1639 00001A20            826              MOVE.B  (MOUVAL),D3
00001440  B63C 0000                827              CMP.B   #0,D3        ;MIRAMOS SI HA SIDO PULSADO EL MOUSE
00001444  6700 006A                828              BEQ     .END         ;SI ES IGUAL A 0, MOUSE NOT PRESSED
00001448                           829  ; --------------------------CHECK IF MOUSE INSIDE------------------------------
00001448  3239 00001A1E            830              MOVE.W  (MOUX),D1
0000144E  B27C 0010                831              CMP.W   #GRDXOFF,D1  ;MOUSE ESTÁ A LA DERECHA DEL MARGEN IZQ?            
00001452  6F00 005C                832              BLE     .END         ;SI MOUSE A LA IZQ DEL GRID(MARGEN NO INCLUIDO)
00001456  0441 0010                833              SUB.W   #GRDXOFF,D1  ;OBTENEMOS POSICIÓN RELATIVA RESPECTO MATRIZ
0000145A  B27C 0300                834              CMP.W   #GRDPXWID,D1 ;MIRAMOS SI ESTÁ A LA IZQ DEL MARGEN DERECHO
0000145E  6C00 0050                835              BGE     .END         ;ESTÁ FUERA DE LA MATRIZ(MARGEN NO INCLUIDO)           
00001462  3439 00001A1C            836              MOVE.W  (MOUY),D2    ;ALMACENAMOS COORDS Y DEL MOUSE
00001468  B47C 009E                837              CMP.W   #GRDYOFF,D2  ;
0000146C  6F00 0042                838              BLE     .END         ;ESTÁ MAS ARRIBA
00001470  0442 009E                839              SUB.W   #GRDYOFF,D2  ;OBTENEMOS POSICIÓN RELATIVA RESPECTO MATRIZ
00001474  B47C 0180                840              CMP.W   #GRDPXHEI,D2
00001478  6C00 0036                841              BGE     .END         ;ESTÁ MÁS ABAJO, FUERA
0000147C                           842  ;-------------------------OBTENEMOS CASILLA CORRESPONDIENTE--------------------
0000147C  83FC 000C                843              DIVS.W  #GRDSZCEL,D1 ;OBTENEMOS COLUMNA(COORDS X)
00001480  85FC 000C                844              DIVS.W  #GRDSZCEL,D2 ;OBTENEMOS FILA(COORDS Y)
00001484                           845  ;-------------------------MIRAMOS QUE BOTÓN DEL MOUSE ESTÁ PULSADO-------------
00001484  41F9 00001A64            846              LEA  GRDDST,A0  ;APUNTAMOS A LA MATRIZ                         
0000148A                           847              ;NşElemento=fila*64+columna.     
0000148A  3002                     848              MOVE.W  D2,D0          
0000148C  C1FC 0040                849              MULS.W  #GRDWIDTH,D0
00001490  D041                     850              ADD.W   D1,D0
00001492  C63C 0001                851              AND.B   #MOUMSKLF,D3 ;LEFT CLICK?
00001496  6700 0014                852              BEQ     .RGT_GRID    ;NO --> RIGHT CLICK
0000149A                           853              ;AŃADIR/PINTAR
0000149A  1801                     854              MOVE.B  D1,D4          ;GUARDAMOS LA FILA
0000149C  89FC 0020                855              DIVS.W  #GRDWIDTH/2,D4 ;OBTENEMOS 0/1, DEPENDIENDO DE LA MITAD          COMMA EXPECTED
000014A0  5204                     856              ADDQ.B  #1,D4          ;SUMAMOS 1 PARA OBTENER EL VALUE
000014A2                           857  ;------------------------CAMBIAMOS VALOR DE LA MATRIZ--------------------------   
000014A2  1184 0000                858              MOVE.B  D4,(A0,D0)
000014A6  4EF9 000014B0            859              JMP     .END
000014AC                           860  ;------------------------ACTUALIZAMOS CONTADORES DE CÉLULAS--------------------
000014AC                           861  
000014AC                           862  .RGT_GRID    
000014AC  4230 0000                863              CLR.B (A0,D0)
000014B0                           864  ;-----------------------FINAL SUBRUTINA----------------------------------------  
000014B0                           865  .END
000014B0  4CDF 011F                866              MOVEM.L (A7)+,D0-D4/A0
000014B4  4E75                     867              RTS
