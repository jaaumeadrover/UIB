000013AA  343C 0009                713              MOVE.W  #BTLMXVDB-1,D2          ;ASSIGNAM NOMBRE ITERACIONS A D2
000013AE  0C90 FFFFFFFF            714  .LOOP       CMP.L   #$FFFFFFFF,(A0)         ;MIRAM SI ESTA BUIT EL BOTÓ
000013B4  6700 000C                715              BEQ     .FINAL                 ;SI=HEM RECORREGUT TOTA LA LLISTA
000013B8                           716  
