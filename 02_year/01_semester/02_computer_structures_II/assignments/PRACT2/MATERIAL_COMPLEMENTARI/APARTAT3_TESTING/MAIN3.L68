00001288  6700 0012                532              BEQ     .CLEARC
0000128C  0040 0004                533              ORI.W   #$04, D0                ;POSAM C A 1
00001290  2429 0008                534              MOVE.L  8(A1), D2               ;OBTENIM EL CALLBACK
00001294  2242                     535              MOVE.L  D2, A1
