00001BC4                          1649  ; INPUT    : NONE
00001BC4                          1650  ; OUTPUT   : NONE
00001BC4                          1651  ; MODIFIES : NONE
00001BC4                          1652  ; -----------------------------------------------------------------------------
00001BC4  13FC 0000 00002CD6      1653              MOVE.B  #GOLSPAUS,(GOLSTATE)
00001BCC  4E75                    1654              RTS
