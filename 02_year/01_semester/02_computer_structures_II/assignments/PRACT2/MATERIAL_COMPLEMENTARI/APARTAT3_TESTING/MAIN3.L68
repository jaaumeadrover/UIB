000014BE                           861  ;----------------------------FINAL SUBRUTINA-----------------------------------
000014BE                           862  .FINAL      
000014BE  4CDF 010F                863              MOVEM.L (A7)+, D0-D3/A0         ;RESTAURAM REGISTRES
000014C2  4E75                     864              RTS
000014C4                           865  
000014C4                           866  ; -----------------------------------------------------------------------------
000014C4                           867  GRDRUPD
000014C4                           868  ; UPDATES THE GRID ACCORDING TO 2-PLAYER GAME OF LIFE RULES AS FOLLOWS:
000014C4                           869  ; * ADDS 1 TO THE NUMBER OF GENERATIONS (GRDNGEN)
000014C4                           870  ; * SWITCHES THE MATRIX POINTERS (GRDDST AND GRDSRC).
000014C4                           871  ; * CHECKS THE NEIGHBORS USING THE NEW SOURCE MATRIX (POINTER BY GRDDRC)
000014C4                           872  ; * THE RESULTS OF APPLYING THE RULES ARE WRITTEN INTO THE NEW DESTINATION
000014C4                           873  ;   MATRIX (POINTED BY GRDDST).
000014C4                           874  ; * THE RULES ARE THE FOLLOWING, WHERE P1 AND P2 ARE 1 AND 2 RESPECTIVELY,
000014C4                           875  ;   DEAD CELLS ARE REPRESENTED BY 0 AND NP1 AND NP2 DENOTE THE NUMBER OF
000014C4                           876  ;   PLAYER 1 AND PLAYER 2 NEIGHBORS RESPECTIVELY:
000014C4                           877  ;   + SURVIVAL RULES
000014C4                           878  ;     - IF CELL IS P1 AND NP1-NP2 IS 2 OR 3 -> NEW VALUE IS P1
000014C4                           879  ;     - IF CELL IS P1 AND NP1-NP2 IS 1 AND NP1>=2 -> NEW VALUE IS P1
000014C4                           880  ;     - OTHERWISE -> NEW VALUE IS 0
000014C4                           881  ;     - IF CELL IS P2 AND NP2-NP1 IS 2 OR 3 -> NEW VALUE IS P2
000014C4                           882  ;     - IF CELL IS P2 AND NP2-NP1 IS 1 AND NP2>=2 -> NEW VALUE IS P2
000014C4                           883  ;     - OTHERWISE -> NEW VALUE IS 0
000014C4                           884  ;   + BIRTH RULES
000014C4                           885  ;     - THE CELL HAS EXACTLY THREE P1 NEIGHBOURS AND THE NUMBER
000014C4                           886  ;       OF P2 NEIGHBOURS IS DIFFERENT FROM THREE. IN THIS CASE A
000014C4                           887  ;       P1 TOKEN IS BORN IN THE CELL.
000014C4                           888  ;     - THE CELL HAS EXACTLY THREE P2 NEIGHBOURS AND THE NUMBER
000014C4                           889  ;       OF P1 NEIGHBOURS IS DIFFERENT FROM THREE. IN THIS CASE A
000014C4                           890  ;       P2 TOKEN IS BORN IN THE CELL.
000014C4                           891  ;     - THE CELL HAS EXACTLY THREE WHITE AND THREE BLACK NEIGHBOURS.
000014C4                           892  ;       IN THIS CASE AN UNBIASED COIN DETERMINES WHETHER A WHITE OR
000014C4                           893  ;       BLACK TOKEN IS BORN IN THE CELL.
000014C4                           894  ; INPUT    : NONE
000014C4                           895  ; OUTPUT   : NONE
000014C4                           896  ; MODIFIES : NONE
000014C4                           897  ; -----------------------------------------------------------------------------
000014C4                           898  
000014C4                           899  ; TODO : PLACE YOUR CODE HERE
