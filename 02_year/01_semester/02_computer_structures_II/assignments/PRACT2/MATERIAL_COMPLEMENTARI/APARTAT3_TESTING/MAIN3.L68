00001440  B23C 0000                827              CMP.B   #0,D1
00001444  6700 0078                828              BEQ     .FINAL                  ;SI NO PITJAT->FINAL
00001448                           829              
00001448                           830  ;-----------------------COMPROVAM SI EL RATOLÍ ESTŔ DINS LA MATRIU-------------
00001448  0C79 006E 00001C84       831              CMP     #GRDVEMRG, (MOUY)
00001450  6D00 006C                832              BLT     .FINAL                  
00001454  303C 006E                833              MOVE.W  #GRDVEMRG, D0
00001458  C0FC 0040                834              MULU    #GRDWIDTH, D0
0000145C  B079 00001C84            835              CMP     (MOUY), D0              
00001462  6F00 005A                836              BLE     .FINAL
00001466                           837  ;-----------------------ACTUALITZAM LA MATRIU----------------------------------
00001466  2079 00001CCC            838              MOVE.L  (GRDDST), A0            ;APUNTAM A LA MATRIU DESTÍ
0000146C  303C 0040                839              MOVE.W  #GRDWIDTH, D0           ; PUT NR OF COLUMNS IN D0
00001470  3639 00001C84            840              MOVE.W  (MOUY), D3              ; GET MOUSE POSITION
00001476  0443 009E                841              SUB.W   #GRDYOFF, D3            ; INITIAL Y
