00001ABC                          1538              INCLUDE "GOL.X68"               ; GAME OF LIFE APPLICATION
00001ABC                          1539  ; =============================================================================
00001ABC                          1540  ; TITLE    : GAME OF LIFE APPLICATION
00001ABC                          1541  ; AUTHOR   : ANTONI BURGUERA
00001ABC                          1542  ; HISTORY  : 05-JULY-2021 - CREATION
00001ABC                          1543  ; COMMENTS : THIS IS AN APPLICATION. SO, IT IMPLEMENTS INITIALIZATION, UPDATE
00001ABC                          1544  ;            AND PLOT, AS WELL AS SOME AUXILIARY SUBROUTINES.
00001ABC                          1545  ; =============================================================================
00001ABC                          1546  
00001ABC                          1547  ; -----------------------------------------------------------------------------
00001ABC                          1548  GOLINIT
00001ABC                          1549  ; INITIALIZE GAME OF LIFE APPLICATION AS FOLLOWS:
00001ABC                          1550  ; * MAKES THE INTERNAL STATE TO BE "PAUSED/STOPPED"
00001ABC                          1551  ; * INITIALIZES THE USER INTERFACE (BY INITIALIZING THE BUTTONS LIST AND
00001ABC                          1552  ;   ADDING BUTTONS INTO IT)
00001ABC                          1553  ; * INITIALIZES THE GRID.
00001ABC                          1554  ; * INITIALIZES THE UTILITY CODE.
00001ABC                          1555  ; INPUT    : NONE
00001ABC                          1556  ; OUTPUT   : NONE
00001ABC                          1557  ; MODIFIES : NONE
00001ABC                          1558  ; -----------------------------------------------------------------------------
00001ABC  48E7 FFFE               1559              MOVEM.L D0-D7/A0-A6,-(A7)
00001AC0  13FC 0000 00002CD6      1560              MOVE.B  #GOLSPAUS,(GOLSTATE)
00001AC8  4EB8 1356               1561              JSR     BTLINIT
00001ACC  41F9 00001AF2           1562              LEA     .SDBLIST,A0
00001AD2  2258                    1563  .LOOP       MOVE.L  (A0)+,A1
00001AD4  B3FC FFFFFFFF           1564              CMP.L   #-1,A1
00001ADA  6700 0008               1565              BEQ     .END
00001ADE  4EB8 1376               1566              JSR     BTLADD
00001AE2  60EE                    1567              BRA     .LOOP
00001AE4  4EB8 13F0               1568  .END        JSR     GRDINIT
00001AE8  4EB8 10DC               1569              JSR     UTLINIT
00001AEC  4CDF 7FFF               1570              MOVEM.L (A7)+,D0-D7/A0-A6
00001AF0  4E75                    1571              RTS
00001AF2= 00001BCE 00001BE0 ...   1572  .SDBLIST    DC.L    GOLCLRBT,GOLRUNBT,GOLSTPBT,GOLSTEBT,GOLLLFBT,GOLLRTBT
00001B0A= 00001C42 00001C58 ...   1573              DC.L    GOLLOABT,GOLSAVBT,-1
00001B16                          1574  
00001B16                          1575  ; -----------------------------------------------------------------------------
00001B16                          1576  GOLUPD
00001B16                          1577  ; UPDATE GAME OF LIFE APPLICATION AS FOLLOWS:
00001B16                          1578  ; * UPDATES THE BUTTON LIST
00001B16                          1579  ; * EXECUTES CODE DEPENDING ON THE CURRENT APPLICATION STATE.
00001B16                          1580  ; INPUT    : NONE
00001B16                          1581  ; OUTPUT   : NONE
00001B16                          1582  ; MODIFIES : NONE
00001B16                          1583  ; -----------------------------------------------------------------------------
00001B16  48E7 C0C0               1584              MOVEM.L A0-A1/D0-D1,-(A7)
00001B1A  4EB8 13A0               1585              JSR     BTLUPD
00001B1E  41F9 00001B3A           1586              LEA     .JMPTBL,A0
00001B24  4280                    1587              CLR.L   D0
00001B26  1039 00002CD6           1588              MOVE.B  (GOLSTATE),D0
00001B2C  E508                    1589              LSL.B   #2,D0
00001B2E  2070 0000               1590              MOVE.L  (A0,D0),A0
00001B32  4E90                    1591              JSR     (A0)
00001B34  4CDF 0303               1592              MOVEM.L (A7)+,A0-A1/D0-D1
00001B38  4E75                    1593              RTS
00001B3A= 00001430 00001B4A       1594  .JMPTBL     DC.L    GRDMUPD,GOLDORUN
00001B42                          1595  
00001B42                          1596  ; -----------------------------------------------------------------------------
00001B42                          1597  GOLPLOT
00001B42                          1598  ; PLOTS THE APPLICATION BY CALLING BTLPLOT AND GRDPLOT
00001B42                          1599  ; INPUT    : NONE
00001B42                          1600  ; OUTPUT   : NONE
00001B42                          1601  ; MODIFIES : NONE
00001B42                          1602  ; -----------------------------------------------------------------------------
00001B42  4EB8 13C8               1603              JSR     BTLPLOT
00001B46  4EF8 1952               1604              JMP     GRDPLOT
00001B4A                          1605  
00001B4A                          1606  ; -----------------------------------------------------------------------------
00001B4A                          1607  GOLDORUN
00001B4A                          1608  ; EXECUTES THE RUN STATE. IT ALSO CHECKS IF THE MAXIMUM NUMBER OF GENERATIONS
00001B4A                          1609  ; IS REACHED AND, IF SO, ANNOUNCES THE WINNER.
00001B4A                          1610  ; INPUT    : NONE
00001B4A                          1611  ; OUTPUT   : NONE
00001B4A                          1612  ; MODIFIES : NONE
00001B4A                          1613  ; -----------------------------------------------------------------------------
00001B4A  48E7 8040               1614              MOVEM.L D0/A1,-(A7)
00001B4E  0C79 00FA 00002CD4      1615              CMP.W   #GOLMAXGN,(GRDNGEN)
00001B56  6D00 0034               1616              BLT     .DOIT
00001B5A  43F9 00001BAC           1617              LEA     .TIE,A1
00001B60  3039 00002CD0           1618              MOVE.W  (GRDNPLR1),D0
00001B66  B079 00002CD2           1619              CMP.W   (GRDNPLR2),D0
00001B6C  6700 0012               1620              BEQ     .PLAYSOUND
00001B70  43F9 00001B96           1621              LEA     .P1WINS,A1
00001B76  6E00 0008               1622              BGT     .PLAYSOUND
00001B7A  43F9 00001BA1           1623              LEA     .P2WINS,A1
00001B80  103C 0046               1624  .PLAYSOUND  MOVE.B  #70,D0
00001B84  4E4F                    1625              TRAP    #15
00001B86  4EB9 00001BC4           1626  .NOSOUND    JSR     GOLTOPAU
00001B8C  4EB8 14C4               1627  .DOIT       JSR     GRDRUPD
00001B90  4CDF 0201               1628              MOVEM.L (A7)+,D0/A1
00001B94  4E75                    1629              RTS
00001B96= 50 31 57 49 4E 53 ...   1630  .P1WINS     DC.B    'P1WINS.WAV',0
00001BA1= 50 32 57 49 4E 53 ...   1631  .P2WINS     DC.B    'P2WINS.WAV',0
00001BAC= 54 49 45 2E 57 41 ...   1632  .TIE        DC.B    'TIE.WAV',0
00001BB4                          1633              DS.W    0
00001BB4                          1634  
00001BB4                          1635  ; -----------------------------------------------------------------------------
00001BB4                          1636  GOLTORUN
00001BB4                          1637  ; SWITCHES TO RUN STATE
00001BB4                          1638  ; INPUT    : NONE
00001BB4                          1639  ; OUTPUT   : NONE
00001BB4                          1640  ; MODIFIES : NONE
00001BB4                          1641  ; -----------------------------------------------------------------------------
00001BB4  4279 00002CD4           1642              CLR.W   (GRDNGEN)               ; CLEAR GENERATIONS COUNT
00001BBA  13FC 0001 00002CD6      1643              MOVE.B  #GOLSEXEC,(GOLSTATE)
00001BC2  4E75                    1644              RTS
00001BC4                          1645  
00001BC4                          1646  ; -----------------------------------------------------------------------------
