00001494  6600 0022                849              BNE     .ESBORRAR
00001498  B47C 0020                850              CMP.W   #GRDWIDTH/2, D2        ; CHECK IF PLR1 OR PLR2
0000149C  6C00 000E                851              BGE     .PLR2
