000013F0                           755              INCLUDE "GRID_DEFINITIU.X68"    ; GRID MANAGEMENT
000013F0                           756  ; =============================================================================
000013F0                           757  ; TITLE    : GRID MANAGEMENT
000013F0                           758  ; AUTHOR   : ANTONI BURGUERA
000013F0                           759  ; HISTORY  : 05-JULY-2021 - CREATION
000013F0                           760  ; COMMENTS : * THERE ARE TWO MATRICES (GRDMATR0 AND GRDMATR1) AND TWO POINTERS
000013F0                           761  ;              TO THESE MATRICES (GRDSRC AND GRDDST).
000013F0                           762  ;
000013F0                           763  ;            * THE MATRIX TO BE PLOTTED IS ALWAYS THE ONE POINTED BY GRDDST.
000013F0                           764  ;
000013F0                           765  ;            * THE MATRIX TO BE UPDATED BY THE MOUSE (GRDMUPD) IS ALWAYS THE
000013F0                           766  ;              ONE POINTED BY GRDDST.
000013F0                           767  ;
000013F0                           768  ;            * THE RULES-UPDATE (GRDRUPD) SWITCHES THE POINTERS AND THEN READS
000013F0                           769  ;              THE NEW SOURCE MATRIX (GRDSRC) TO DETERMINE THE NUMBER OF
000013F0                           770  ;              NEIGHBORS. THE RESULTING CELL VALUE IS WRITTEN TO THE DESTINA-
000013F0                           771  ;              TION MATRIX, POINTED BY GRDDST.
000013F0                           772  ; =============================================================================
000013F0                           773  
000013F0                           774  ; -----------------------------------------------------------------------------
000013F0                           775  GRDINIT
000013F0                           776  ; INITIALIZE THE GRID AS FOLLOWS:
000013F0                           777  ; * POINTS THE SOURCE GRID POINTER TO GRDMATR0.
000013F0                           778  ; * POINTS THE DESTINATION GRID POINTER TO GRDMATR1.
000013F0                           779  ; * RESETS THE COUNTERS (GRDNPLR1, GRDNPLR2, GRDNGEN).
000013F0                           780  ; * FILLS THE TWO MATRICES (GRDMATR0 AND GRDMATR1) WITH ZEROS.
000013F0                           781  ; INPUT    : NONE
000013F0                           782  ; OUTPUT   : NONE
000013F0                           783  ; MODIFIES : NONE
000013F0                           784  ; -----------------------------------------------------------------------------
000013F0  48E7 8080                785              MOVEM.L A0/D0,-(A7)
000013F4  23FC 000022CA 000022C2   786              MOVE.L  #GRDMATR0,(GRDSRC)
000013FE  23FC 00002ACA 000022C6   787              MOVE.L  #GRDMATR1,(GRDDST)
00001408  4279 000032CA            788              CLR.W   (GRDNPLR1)
0000140E  4279 000032CC            789              CLR.W   (GRDNPLR2)
00001414  4279 000032CE            790              CLR.W   (GRDNGEN)
0000141A  41F9 000022CA            791              LEA     GRDMATR0,A0
00001420  303C 0FFF                792              MOVE.W  #GRDWIDTH*GRDHEIGH*2-1,D0
00001424  4218                     793  .LOOP       CLR.B   (A0)+
00001426  51C8 FFFC                794              DBRA.W  D0,.LOOP
0000142A  4CDF 0101                795              MOVEM.L (A7)+,A0/D0
0000142E  4E75                     796              RTS
00001430                           797  
00001430                           798  ; -----------------------------------------------------------------------------
00001430                           799  GRDMUPD
00001430                           800  ; GRID UPDATE USING MOUSE. THE INTERFACE IS AS FOLLOWS:
00001430                           801  ; * IF MOUSE IS NOT PRESSED OR IS OUTSIDE THE PLOTTED GRID, DOES NOTHING.
00001430                           802  ; * IF LEFT MOUSE BUTTON IS PRESSED INSIDE THE GRID:
00001430                           803  ;   - A PLAYER 1 (VALUE=1) CELL IS CREATED AT THE MOUSE POSITION IF THE MOUSE
00001430                           804  ;     IS ON THE LEFT HALF OF THE GRID.
00001430                           805  ;   - A PLAYER 2 (VALUE=2) CELL IS CREATED AT THE MOUSE POSITION IF THE MOUSE
00001430                           806  ;     IS ON THE RIGHT HALF OF THE GRID.
00001430                           807  ; * IF RIGHT MOUSE BUTTON IS PRESSED INSIDE THE GRID, THE CELL WHERE THE MOUSE
00001430                           808  ;   IS IS CLEARED (VALUE=0).
00001430                           809  ; INPUT    : NONE
00001430                           810  ; OUTPUT   : NONE
00001430                           811  ; MODIFIES : NONE
00001430                           812  ; -----------------------------------------------------------------------------
00001430                           813  
00001430                           814  ; TODO : PLACE YOUR CODE HERE
00001430  48E7 F080                815              MOVEM.L D0-D3/A0, -(A7)
00001434  4281                     816              CLR.L   D1                      ; WILL BE USED FOR DIVIDE OP
00001436  4282                     817              CLR.L   D2
00001438  123C 0003                818              MOVE.B  #MOUMSKLF+MOUMSKRT, D1
0000143C  1639 00002282            819              MOVE.B  (MOUVAL), D3
00001442  C601                     820              AND.B   D1, D3
00001444  4A03                     821              TST.B   D3
00001446  6700 0074                822              BEQ     .END
0000144A  0C79 006E 0000227E       823              CMP     #GRDVEMRG, (MOUY)
00001452  6D00 0068                824              BLT     .END
00001456  303C 006E                825              MOVE.W  #GRDVEMRG, D0
0000145A  C0FC 0040                826              MULU    #GRDWIDTH, D0
0000145E  B079 0000227E            827              CMP     (MOUY), D0
00001464  6F00 0056                828              BLE     .END
00001468  2079 000022C6            829              MOVE.L  (GRDDST), A0            ; A0: POINTER TO THE DATA TO WRITE
0000146E  303C 0040                830              MOVE.W  #GRDWIDTH, D0           ; PUT NR OF COLUMNS IN D0
00001472  3439 0000227E            831              MOVE.W  (MOUY), D2              ; GET MOUSE POSITION
00001478  0442 009E                832              SUB.W   #GRDYOFF, D2            ; INITIAL Y
0000147C  85FC 000C                833              DIVS.W  #GRDSZCEL, D2           ; GET Y OFFSET                     
00001480  C0C2                     834              MULU.W  D2, D0
00001482  3239 00002280            835              MOVE.W  (MOUX), D1              
00001488  0441 0010                836              SUB.W   #GRDXOFF, D1            ; INITIAL X
0000148C  83FC 000C                837              DIVS.W  #GRDSZCEL, D1           ; GET X OFFSET
00001490  D041                     838              ADD.W   D1, D0
00001492  0803 0001                839              BTST.L  #MOUMSKLF, D3           ; IS RIGHT CLICK?
00001496  6600 001E                840              BNE     .DELETE
0000149A  B27C 0020                841              CMP.W   #GRDWIDTH/2, D1         ; CHECK IF PLR1 OR PLR2
0000149E  6C00 000C                842              BGE     .PLR2
000014A2  11BC 0001 0000           843              MOVE.B  #1,(A0, D0)
000014A8  6000 0012                844              BRA     .END
000014AC  11BC 0002 0000           845  .PLR2       MOVE.B  #2, (A0, D0)
000014B2  6000 0008                846              BRA     .END
000014B6  11BC 0000 0000           847  .DELETE     MOVE.B  #0, (A0, D0)
000014BC  4CDF 010F                848  .END        MOVEM.L (A7)+, D0-D3/A0
000014C0  4E75                     849              RTS
000014C2                           850  
000014C2                           851  ; -----------------------------------------------------------------------------
000014C2                           852  GRDRUPD
000014C2                           853  ; UPDATES THE GRID ACCORDING TO 2-PLAYER GAME OF LIFE RULES AS FOLLOWS:
000014C2                           854  ; * ADDS 1 TO THE NUMBER OF GENERATIONS (GRDNGEN)
000014C2                           855  ; * SWITCHES THE MATRIX POINTERS (GRDDST AND GRDSRC).
000014C2                           856  ; * CHECKS THE NEIGHBORS USING THE NEW SOURCE MATRIX (POINTER BY GRDDRC)
000014C2                           857  ; * THE RESULTS OF APPLYING THE RULES ARE WRITTEN INTO THE NEW DESTINATION
000014C2                           858  ;   MATRIX (POINTED BY GRDDST).
000014C2                           859  ; * THE RULES ARE THE FOLLOWING, WHERE P1 AND P2 ARE 1 AND 2 RESPECTIVELY,
000014C2                           860  ;   DEAD CELLS ARE REPRESENTED BY 0 AND NP1 AND NP2 DENOTE THE NUMBER OF
000014C2                           861  ;   PLAYER 1 AND PLAYER 2 NEIGHBORS RESPECTIVELY:
000014C2                           862  ;   + SURVIVAL RULES
000014C2                           863  ;     - IF CELL IS P1 AND NP1-NP2 IS 2 OR 3 -> NEW VALUE IS P1
000014C2                           864  ;     - IF CELL IS P1 AND NP1-NP2 IS 1 AND NP1>=2 -> NEW VALUE IS P1
000014C2                           865  ;     - OTHERWISE -> NEW VALUE IS 0
000014C2                           866  ;     - IF CELL IS P2 AND NP2-NP1 IS 2 OR 3 -> NEW VALUE IS P2
000014C2                           867  ;     - IF CELL IS P2 AND NP2-NP1 IS 1 AND NP2>=2 -> NEW VALUE IS P2
000014C2                           868  ;     - OTHERWISE -> NEW VALUE IS 0
000014C2                           869  ;   + BIRTH RULES
000014C2                           870  ;     - THE CELL HAS EXACTLY THREE P1 NEIGHBOURS AND THE NUMBER
000014C2                           871  ;       OF P2 NEIGHBOURS IS DIFFERENT FROM THREE. IN THIS CASE A
000014C2                           872  ;       P1 TOKEN IS BORN IN THE CELL.
000014C2                           873  ;     - THE CELL HAS EXACTLY THREE P2 NEIGHBOURS AND THE NUMBER
000014C2                           874  ;       OF P1 NEIGHBOURS IS DIFFERENT FROM THREE. IN THIS CASE A
000014C2                           875  ;       P2 TOKEN IS BORN IN THE CELL.
000014C2                           876  ;     - THE CELL HAS EXACTLY THREE WHITE AND THREE BLACK NEIGHBOURS.
000014C2                           877  ;       IN THIS CASE AN UNBIASED COIN DETERMINES WHETHER A WHITE OR
000014C2                           878  ;       BLACK TOKEN IS BORN IN THE CELL.
000014C2                           879  ; INPUT    : NONE
000014C2                           880  ; OUTPUT   : NONE
000014C2                           881  ; MODIFIES : NONE
000014C2                           882  ; -----------------------------------------------------------------------------
000014C2                           883  
000014C2                           884  ; TODO : PLACE YOUR CODE HERE
000014C2  48E7 F9F8                885              MOVEM.L D0-D4/D7/A0-A4, -(A7)
000014C6  4284                     886              CLR.L   D4
000014C8  4240                     887              CLR.W   D0
000014CA  3039 000032CE            888              MOVE.W  (GRDNGEN), D0           ; ADD 1 TO GENERATION NR
