00001C64                          1528  GRDSAVE
00001C64                          1529  ; SAVES THE GRID INTO A FILE IN CSV FORMAT
00001C64                          1530  ; INPUT    : NONE
00001C64                          1531  ; OUTPUT   : NONE
00001C64                          1532  ; MODIFIES : NONE
00001C64                          1533  ; NOTE     : THE LOCAL BUFFER SIZE MUST BE MAX(512,2*GRDWIDTH+1). PLEASE CHANGE
00001C64                          1534  ;            IT ACCORDINGLY IF GRDWIDTH*2+1 IS LARGER THAN 512.
00001C64                          1535  ; -----------------------------------------------------------------------------
00001C64  48E7 FFFE               1536              MOVEM.L D0-D7/A0-A6,-(A7)       ; TO BE OPTIMIZED
00001C68  103C 0032               1537              MOVE.B  #50,D0                  ; CLOSE ALL FILES (RECOMMENDED)
00001C6C  4E4F                    1538              TRAP    #15
00001C6E  9FFC 00000200           1539              SUB.L   #512,A7                 ; ROW BUFFER IN LOCAL MEMORY
00001C74  103C 003A               1540              MOVE.B  #58,D0                  ; SHOW FILE DIALOG TASK
00001C78  7201                    1541              MOVE.L  #1,D1                   ; DISPLAY SAVE DIALOG
00001C7A  43F9 00001CF0           1542              LEA     .MSG,A1                 ; STANDARD MESSAGE
00001C80  45F9 00001D0A           1543              LEA     .FILTER,A2              ; NO FILTER
