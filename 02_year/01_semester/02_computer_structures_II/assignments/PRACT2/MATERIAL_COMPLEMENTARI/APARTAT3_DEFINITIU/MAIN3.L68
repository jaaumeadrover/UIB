00001C8A  4E4F                    1546              TRAP    #15
00001C8C  4A01                    1547              TST.B   D1
00001C8E  6700 0054               1548              BEQ     .END                    ; IF CANCELLED, DO NOTHING
00001C92  224B                    1549              MOVE.L  A3,A1                   ; PLACE THE FILENAME INTO A1
00001C94  103C 0034               1550              MOVE.B  #52,D0                  ; CREATE NEW FILE
00001C98  4E4F                    1551              TRAP    #15
00001C9A  4A40                    1552              TST.W   D0                      ; CHECK CREATION ERROR
00001C9C  6600 0046               1553              BNE     .END                    ; DO NOTHING MORE IF ERROR
00001CA0  2C4F                    1554              MOVE.L  A7,A6                   ; PUT A6 INTO START OF BUFFER
00001CA2  224F                    1555              MOVE.L  A7,A1                   ; PUT A1 INTO START OF BUFFER
00001CA4  2079 000022C6           1556              MOVE.L  (GRDDST), A0            ; A0: POINTER TO THE DATA TO WRITE
