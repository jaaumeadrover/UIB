00001BBC= 54 49 45 2E 57 41 ...   1632  .TIE        DC.B    'TIE.WAV',0
00001BC4                          1633              DS.W    0
00001BC4                          1634  
00001BC4                          1635  ; -----------------------------------------------------------------------------
00001BC4                          1636  GOLTORUN
00001BC4                          1637  ; SWITCHES TO RUN STATE
00001BC4                          1638  ; INPUT    : NONE
00001BC4                          1639  ; OUTPUT   : NONE
00001BC4                          1640  ; MODIFIES : NONE
00001BC4                          1641  ; -----------------------------------------------------------------------------
