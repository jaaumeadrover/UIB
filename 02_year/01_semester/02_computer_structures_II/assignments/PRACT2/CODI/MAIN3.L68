000013F0                           761              INCLUDE "GRID.X68"              ; GRID MANAGEMENT
000013F0                           762  ; =============================================================================
000013F0                           763  ; TITLE    : GRID MANAGEMENT
000013F0                           764  ; AUTHOR   : ANTONI BURGUERA
000013F0                           765  ; HISTORY  : 05-JULY-2021 - CREATION
000013F0                           766  ; COMMENTS : * THERE ARE TWO MATRICES (GRDMATR0 AND GRDMATR1) AND TWO POINTERS
000013F0                           767  ;              TO THESE MATRICES (GRDSRC AND GRDDST).
000013F0                           768  ;
000013F0                           769  ;            * THE MATRIX TO BE PLOTTED IS ALWAYS THE ONE POINTED BY GRDDST.
000013F0                           770  ;
000013F0                           771  ;            * THE MATRIX TO BE UPDATED BY THE MOUSE (GRDMUPD) IS ALWAYS THE
000013F0                           772  ;              ONE POINTED BY GRDDST.
000013F0                           773  ;
000013F0                           774  ;            * THE RULES-UPDATE (GRDRUPD) SWITCHES THE POINTERS AND THEN READS
000013F0                           775  ;              THE NEW SOURCE MATRIX (GRDSRC) TO DETERMINE THE NUMBER OF
000013F0                           776  ;              NEIGHBORS. THE RESULTING CELL VALUE IS WRITTEN TO THE DESTINA-
000013F0                           777  ;              TION MATRIX, POINTED BY GRDDST.
000013F0                           778  ; =============================================================================
000013F0                           779  
000013F0                           780  ; -----------------------------------------------------------------------------
000013F0                           781  GRDINIT
000013F0                           782  ; INITIALIZE THE GRID AS FOLLOWS:
000013F0                           783  ; * POINTS THE SOURCE GRID POINTER TO GRDMATR0.
000013F0                           784  ; * POINTS THE DESTINATION GRID POINTER TO GRDMATR1.
000013F0                           785  ; * RESETS THE COUNTERS (GRDNPLR1, GRDNPLR2, GRDNGEN).
000013F0                           786  ; * FILLS THE TWO MATRICES (GRDMATR0 AND GRDMATR1) WITH ZEROS.
000013F0                           787  ; INPUT    : NONE
000013F0                           788  ; OUTPUT   : NONE
000013F0                           789  ; MODIFIES : NONE
000013F0                           790  ; -----------------------------------------------------------------------------
000013F0  48E7 8080                791              MOVEM.L A0/D0,-(A7)
000013F4  23FC 00001CE0 00001CD8   792              MOVE.L  #GRDMATR0,(GRDSRC)
000013FE  23FC 000024E0 00001CDC   793              MOVE.L  #GRDMATR1,(GRDDST)
00001408  4279 00002CE0            794              CLR.W   (GRDNPLR1)
0000140E  4279 00002CE2            795              CLR.W   (GRDNPLR2)
00001414  4279 00002CE4            796              CLR.W   (GRDNGEN)
0000141A  41F9 00001CE0            797              LEA     GRDMATR0,A0
00001420  303C 0FFF                798              MOVE.W  #GRDWIDTH*GRDHEIGH*2-1,D0
00001424  4218                     799  .LOOP       CLR.B   (A0)+
00001426  51C8 FFFC                800              DBRA.W  D0,.LOOP
0000142A  4CDF 0101                801              MOVEM.L (A7)+,A0/D0
0000142E  4E75                     802              RTS
00001430                           803  
00001430                           804  ; -----------------------------------------------------------------------------
00001430                           805  GRDMUPD
00001430                           806  ; GRID UPDATE USING MOUSE. THE INTERFACE IS AS FOLLOWS:
00001430                           807  ; * IF MOUSE IS NOT PRESSED OR IS OUTSIDE THE PLOTTED GRID, DOES NOTHING.
00001430                           808  ; * IF LEFT MOUSE BUTTON IS PRESSED INSIDE THE GRID:
00001430                           809  ;   - A PLAYER 1 (VALUE=1) CELL IS CREATED AT THE MOUSE POSITION IF THE MOUSE
00001430                           810  ;     IS ON THE LEFT HALF OF THE GRID.
00001430                           811  ;   - A PLAYER 2 (VALUE=2) CELL IS CREATED AT THE MOUSE POSITION IF THE MOUSE
00001430                           812  ;     IS ON THE RIGHT HALF OF THE GRID.
00001430                           813  ; * IF RIGHT MOUSE BUTTON IS PRESSED INSIDE THE GRID, THE CELL WHERE THE MOUSE
00001430                           814  ;   IS IS CLEARED (VALUE=0).
00001430                           815  ; INPUT    : NONE
00001430                           816  ; OUTPUT   : NONE
00001430                           817  ; MODIFIES : NONE
00001430                           818  ; -----------------------------------------------------------------------------
00001430                           819  
00001430                           820  ; TODO : PLACE YOUR CODE HERE
00001430                           821  
00001430                           822   *D0: Mŕscara left/right click,coordsX(columnes)
00001430                           823   *D1:
00001430                           824   *D2:
00001430                           825   *D3:
00001430                           826   
