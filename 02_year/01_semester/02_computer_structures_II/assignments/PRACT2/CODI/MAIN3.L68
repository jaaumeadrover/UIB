00001C94                          1764  ; --- VARIABLES ---------------------------------------------------------------
00001C94                          1765  
00001C94                          1766              INCLUDE "SYSVAR.X68"            ; SYSTEM VARIABLES
00001C94                          1767  ; =============================================================================
00001C94                          1768  ; TITLE    : SYSTEM VARS
00001C94                          1769  ; AUTHOR   : ANTONI BURGUERA
00001C94                          1770  ; HISTORY  : 05-JULY-2021 - CREATION
00001C94                          1771  ; COMMENTS : * ALL THESE VARS ARE USED TO SHARE DATA FROM SYSTEM TO USER. THUS
00001C94                          1772  ;              THEY MUST NOT BE IN PROTECTED MEMORY.
00001C94                          1773  ;
00001C94                          1774  ;            * SINCE SOME SUBROUTINES TAKE ADVANTAGE OF THE ORDER IN WHICH
00001C94                          1775  ;              THE VARIABLES ARE IN MEMORY, THEIR ORDER SHOULD NOT BE ALTERED.
00001C94                          1776  ; =============================================================================
00001C94                          1777  
00001C94                          1778  ; --- MOUSE RELATED VARIABLES -------------------------------------------------
00001C94                          1779  
00001C94                          1780  MOUY        DS.W    1                       ; MOUSE Y COORDINATE
00001C96                          1781  MOUX        DS.W    1                       ; MOUSE X COORDINATE
