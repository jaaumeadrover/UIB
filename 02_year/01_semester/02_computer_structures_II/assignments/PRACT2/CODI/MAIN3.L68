00001ACC                          1538              INCLUDE "GOL.X68"               ; GAME OF LIFE APPLICATION
00001ACC                          1539  ; =============================================================================
00001ACC                          1540  ; TITLE    : GAME OF LIFE APPLICATION
00001ACC                          1541  ; AUTHOR   : ANTONI BURGUERA
00001ACC                          1542  ; HISTORY  : 05-JULY-2021 - CREATION
00001ACC                          1543  ; COMMENTS : THIS IS AN APPLICATION. SO, IT IMPLEMENTS INITIALIZATION, UPDATE
00001ACC                          1544  ;            AND PLOT, AS WELL AS SOME AUXILIARY SUBROUTINES.
00001ACC                          1545  ; =============================================================================
00001ACC                          1546  
00001ACC                          1547  ; -----------------------------------------------------------------------------
00001ACC                          1548  GOLINIT
00001ACC                          1549  ; INITIALIZE GAME OF LIFE APPLICATION AS FOLLOWS:
00001ACC                          1550  ; * MAKES THE INTERNAL STATE TO BE "PAUSED/STOPPED"
00001ACC                          1551  ; * INITIALIZES THE USER INTERFACE (BY INITIALIZING THE BUTTONS LIST AND
00001ACC                          1552  ;   ADDING BUTTONS INTO IT)
00001ACC                          1553  ; * INITIALIZES THE GRID.
00001ACC                          1554  ; * INITIALIZES THE UTILITY CODE.
00001ACC                          1555  ; INPUT    : NONE
00001ACC                          1556  ; OUTPUT   : NONE
00001ACC                          1557  ; MODIFIES : NONE
00001ACC                          1558  ; -----------------------------------------------------------------------------
00001ACC  48E7 FFFE               1559              MOVEM.L D0-D7/A0-A6,-(A7)
00001AD0  13FC 0000 00002CE6      1560              MOVE.B  #GOLSPAUS,(GOLSTATE)
00001AD8  4EB8 1356               1561              JSR     BTLINIT
00001ADC  41F9 00001B02           1562              LEA     .SDBLIST,A0
00001AE2  2258                    1563  .LOOP       MOVE.L  (A0)+,A1
00001AE4  B3FC FFFFFFFF           1564              CMP.L   #-1,A1
00001AEA  6700 0008               1565              BEQ     .END
00001AEE  4EB8 1376               1566              JSR     BTLADD
00001AF2  60EE                    1567              BRA     .LOOP
00001AF4  4EB8 13F0               1568  .END        JSR     GRDINIT
00001AF8  4EB8 10DC               1569              JSR     UTLINIT
00001AFC  4CDF 7FFF               1570              MOVEM.L (A7)+,D0-D7/A0-A6
00001B00  4E75                    1571              RTS
00001B02= 00001BDE 00001BF0 ...   1572  .SDBLIST    DC.L    GOLCLRBT,GOLRUNBT,GOLSTPBT,GOLSTEBT,GOLLLFBT,GOLLRTBT
00001B1A= 00001C52 00001C68 ...   1573              DC.L    GOLLOABT,GOLSAVBT,-1
00001B26                          1574  
00001B26                          1575  ; -----------------------------------------------------------------------------
00001B26                          1576  GOLUPD
00001B26                          1577  ; UPDATE GAME OF LIFE APPLICATION AS FOLLOWS:
00001B26                          1578  ; * UPDATES THE BUTTON LIST
00001B26                          1579  ; * EXECUTES CODE DEPENDING ON THE CURRENT APPLICATION STATE.
00001B26                          1580  ; INPUT    : NONE
00001B26                          1581  ; OUTPUT   : NONE
00001B26                          1582  ; MODIFIES : NONE
00001B26                          1583  ; -----------------------------------------------------------------------------
00001B26  48E7 C0C0               1584              MOVEM.L A0-A1/D0-D1,-(A7)
00001B2A  4EB8 13A0               1585              JSR     BTLUPD
00001B2E  41F9 00001B4A           1586              LEA     .JMPTBL,A0
00001B34  4280                    1587              CLR.L   D0
00001B36  1039 00002CE6           1588              MOVE.B  (GOLSTATE),D0
00001B3C  E508                    1589              LSL.B   #2,D0
00001B3E  2070 0000               1590              MOVE.L  (A0,D0),A0
00001B42  4E90                    1591              JSR     (A0)
