00001B48  4E75                    1593              RTS
00001B4A= 00001430 00001B5A       1594  .JMPTBL     DC.L    GRDMUPD,GOLDORUN
00001B52                          1595  
00001B52                          1596  ; -----------------------------------------------------------------------------
00001B52                          1597  GOLPLOT
00001B52                          1598  ; PLOTS THE APPLICATION BY CALLING BTLPLOT AND GRDPLOT
00001B52                          1599  ; INPUT    : NONE
00001B52                          1600  ; OUTPUT   : NONE
00001B52                          1601  ; MODIFIES : NONE
00001B52                          1602  ; -----------------------------------------------------------------------------
00001B52  4EB8 13C8               1603              JSR     BTLPLOT
00001B56  4EF8 1952               1604              JMP     GRDPLOT
00001B5A                          1605  
00001B5A                          1606  ; -----------------------------------------------------------------------------
00001B5A                          1607  GOLDORUN
00001B5A                          1608  ; EXECUTES THE RUN STATE. IT ALSO CHECKS IF THE MAXIMUM NUMBER OF GENERATIONS
00001B5A                          1609  ; IS REACHED AND, IF SO, ANNOUNCES THE WINNER.
00001B5A                          1610  ; INPUT    : NONE
00001B5A                          1611  ; OUTPUT   : NONE
00001B5A                          1612  ; MODIFIES : NONE
00001B5A                          1613  ; -----------------------------------------------------------------------------
