00001356                           626              INCLUDE "BTNLIST.X68"           ; BUTTON LIST MANAGEMENT
00001356                           627  ; =============================================================================
00001356                           628  ; TITLE    : BUTTON LIST MANAGEMENT
00001356                           629  ; AUTHOR   : ANTONI BURGUERA
00001356                           630  ; HISTORY  : 05-JULY-2021 - CREATION
00001356                           631  ; COMMENTS : * ALLOWS ADDING, UPDATING AND PLOTTING A LIST OF BUTTONS. ALLOWS
00001356                           632  ;              REMOVING THEM ALL, BUT NOT INDIVIDUALLY.
00001356                           633  ;
00001356                           634  ;            * THE LIST OF BUTTONS IS STORED AS A LIST OF BUTTON'S VDB. THIS
00001356                           635  ;              LIST IS STORED AT BTLDATA.
00001356                           636  ;
00001356                           637  ;            * THE LIST OF VBD IS BUILT ASSUMING A MAXIMUM OF BTLMXVDB BUTTONS
00001356                           638  ;              AND A SIZE OF BTNSZVDB BYTES FOR EACH VDB.
00001356                           639  ; =============================================================================
00001356                           640  
00001356                           641  ; -----------------------------------------------------------------------------
00001356                           642  BTLINIT
00001356                           643  ; INITIALIZES BUTTON LIST BY SETTING ALL THE POINTERS TO STATIC DATA BLOCKS
00001356                           644  ; TO $FFFFFFFF.
00001356                           645  ; INPUT    : NONE
00001356                           646  ; OUTPUT   : NONE
00001356                           647  ; MODIFIES : NONE
00001356                           648  ; -----------------------------------------------------------------------------
00001356  48E7 8080                649              MOVEM.L D0/A0,-(A7)
0000135A  41F9 00001C9C            650              LEA     BTLDATA,A0
00001360  303C 0009                651              MOVE.W  #BTLMXVDB-1,D0          ; NUM ITERATIONS
00001364  20BC FFFFFFFF            652  .LOOP       MOVE.L  #$FFFFFFFF,(A0)         ; MARK SLOT AS EMPTY
0000136A  5C88                     653              ADD.L   #BTNSZVDB,A0            ; GO TO NEXT SLOT
0000136C  51C8 FFF6                654              DBRA.W  D0,.LOOP                ; LOOP FOR ALL SLOTS
00001370  4CDF 0101                655              MOVEM.L (A7)+,D0/A0
00001374  4E75                     656              RTS
00001376                           657  
00001376                           658  ; -----------------------------------------------------------------------------
00001376  =00001356                659  BTLCLEAR    EQU     BTLINIT
00001376                           660  ; CLEARS THE BUTTON LIST. SAME AS BTLINIT.
00001376                           661  ; INPUT    : NONE
00001376                           662  ; OUTPUT   : NONE
00001376                           663  ; MODIFIES : NONE
00001376                           664  ; -----------------------------------------------------------------------------
00001376                           665  
00001376                           666  ; -----------------------------------------------------------------------------
00001376                           667  BTLADD
00001376                           668  ; ADDS A NEW BUTTON INTO THE BUTTON LIST AND INITS IT.
00001376                           669  ; INPUT    : A1 - POINTER TO THE BUTTON SDB
00001376                           670  ; OUTPUT   : NONE
00001376                           671  ; MODIFIES : NONE
00001376                           672  ; -----------------------------------------------------------------------------
00001376  48E7 8080                673              MOVEM.L A0/D0,-(A7)
0000137A                           674  
0000137A                           675              ; SEARCH FOR AN EMPTY SLOT
0000137A                           676  
0000137A  41F9 00001C9C            677              LEA     BTLDATA,A0
00001380  303C 0009                678              MOVE.W  #BTLMXVDB-1,D0
00001384  0C90 FFFFFFFF            679  .LOOP       CMP.L   #$FFFFFFFF,(A0)
0000138A  6700 000E                680              BEQ     .FOUND
0000138E  5C88                     681              ADD.L   #BTNSZVDB,A0
00001390  51C8 FFF2                682              DBRA.W  D0,.LOOP
00001394                           683  
00001394                           684              ; NO SLOT? DO NOTHING
00001394                           685  
00001394  4CDF 0101                686  .END        MOVEM.L (A7)+,A0/D0
00001398  4E75                     687              RTS
0000139A                           688  
0000139A                           689              ; SLOT FOUND? PLACE THE BUTTON THERE BY CALLING BTNINIT
0000139A                           690  
0000139A  4EB8 1214                691  .FOUND      JSR     BTNINIT
0000139E  60F4                     692              BRA     .END
000013A0                           693  
000013A0                           694  ; -----------------------------------------------------------------------------
000013A0                           695  BTLUPD
000013A0                           696  ; CALLS BTNUPD FOR ALL THE BUTTONS IN THE BUTTON LIST.
000013A0                           697  ; INPUT    : NONE
000013A0                           698  ; OUTPUT   : NONE
000013A0                           699  ; MODIFIES : NONE
000013A0                           700  ; -----------------------------------------------------------------------------
000013A0                           701  
000013A0  48E7 8080                702              MOVEM.L A0/D0,-(A7)
000013A4                           703  
000013A4                           704              ; TRAVERSE THE LIST
000013A4                           705  
000013A4  41F9 00001C9C            706              LEA     BTLDATA,A0
000013AA  303C 0009                707              MOVE.W  #BTLMXVDB-1,D0
000013AE  0C90 FFFFFFFF            708  .LOOP       CMP.L   #$FFFFFFFF,(A0)
000013B4  6700 000C                709              BEQ     .DONE
000013B8                           710  
000013B8                           711              ; UPDATE EACH BUTTON
000013B8                           712  
000013B8  4EB8 121C                713              JSR     BTNUPD
000013BC                           714  
000013BC                           715              ; GO TO THE NEXT BUTTON
000013BC                           716  
000013BC  5C88                     717              ADD.L   #BTNSZVDB,A0
000013BE  51C8 FFEE                718              DBRA.W  D0,.LOOP
000013C2                           719  
000013C2  4CDF 0101                720  .DONE       MOVEM.L (A7)+,A0/D0
000013C6  4E75                     721              RTS
000013C8                           722  
000013C8                           723  
000013C8                           724  ; -----------------------------------------------------------------------------
000013C8                           725  BTLPLOT
000013C8                           726  ; CALLS BTNUPD FOR ALL THE BUTTONS IN THE BUTTON LIST.
000013C8                           727  ; INPUT    : NONE
000013C8                           728  ; OUTPUT   : NONE
000013C8                           729  ; MODIFIES : NONE
000013C8                           730  ; -----------------------------------------------------------------------------
000013C8                           731  
000013C8                           732  ; TODO : PLACE YOUR CODE HERE
000013C8                           733  
000013C8  48E7 2080                734              MOVEM.L A0/D2,-(A7)             ;GUARDAM REGISTRES
000013CC                           735  
000013CC                           736  ; ----------------------BUCLE RECORREGUT SOBRE BOTONS--------------------------
000013CC  41F9 00001C9C            737              LEA     BTLDATA,A0              ;APUNTAM A LA LLISTA
000013D2  343C 0009                738              MOVE.W  #BTLMXVDB-1,D2          ;ASSIGNAM ITERACIONS A D2
000013D6  0C90 FFFFFFFF            739  .LOOP       CMP.L   #$FFFFFFFF,(A0)         ;MIRAM SI FINAL DE LLISTA
000013DC  6700 000C                740              BEQ     .FINAL
000013E0                           741  
000013E0  4EB8 12B6                742              JSR     BTNPLOT                 ;DIBUIXAM BOTÓ
000013E4                           743  
