000010DA                           166  STR2SEG
000010DA                           167  ; CONVERTS A STRING OF 8 CHARS INTO THE 7-SEGMENT DISPLAYS WORDS SEQUENCE,
000010DA                           168  ; READY TO BE SENT TO THE DISPLAYS.
000010DA                           169  ; ACCEPTS CHARACTERS FROM A TO Z AND FROM a TO z AND SPACE. CAPITAL AND NON
000010DA                           170  ; CAPITAL ARE DISPLAYED WITH THE SAME GRAPHIC.
000010DA                           171  ; INPUT    - A0 POINTER TO THE STRING (8 CHAR)
000010DA                           172  ;            A1 POINTER TO THE ADDRESS WHERE TO PUT THE WORDS SEQUENCE
000010DA                           173  ; OUTPUT   - MEMORY FROM (A1) TO (A0+15) MODIFIED.
000010DA                           174  ; MODIFIES - NO REGISTERS MODIFIED
000010DA                           175  ; NOTE     - BEHAVIOR IN FRONT OF CHARS OUTSIDE RANGES A-Z AND a-z AND SPACE
000010DA                           176  ;            IS UNDEFINED
000010DA                           177  ; -----------------------------------------------------------------------------
000010DA  =00000007                178  .CONTADOR EQU 7 ;CONSTANT AMB NOMBRE ITERACIONS
000010DA                           179  
000010DA  48E7 C0E0                180              MOVEM.L D0-D1/A0-A2,-(A7)   ;PUSH,GUARDAM VALORS DINS PILA
000010DE  323C 0007                181              MOVE.W #.CONTADOR,D1        ;ASSIGNAM VALOR AL REGISTRE CONTADOR
