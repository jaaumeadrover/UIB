# Set seed for reproducibility
set.seed(123)
# Subset the dataframe to include only the desired columns
df <- df_scaled[c("sex", "body_mass_g")]
# Using k-means
kmeans_result <- kmeans(df, centers = 4, nstart = 25)
# Extract cluster means
cluster_means <- aggregate(df, by = list(cluster = kmeans_result$cluster), FUN = mean)
# Plot cluster means
plot(cluster_means$sex, cluster_means$body_mass_g, col = 1:4, pch = 16, main = "Cluster Means", xlab = "Sex", ylab = "Body Mass")
# Print cluster means
for (i in 1:kmeans_result$centers) {
cat("Cluster", i-1, "-> Sex:", kmeans_result$centers[i, "sex"], ", Body Mass:", kmeans_result$centers[i, "body_mass_g"], "\n")
}
# Print cluster means
for (i in 1:kmeans_result$centers+1) {
cat("Cluster", i-1, "-> Sex:", kmeans_result$centers[i, "sex"], ", Body Mass:", kmeans_result$centers[i, "body_mass_g"], "\n")
}
# Print cluster means
for (i in 1:kmeans_result$centers+4) {
cat("Cluster", i-1, "-> Sex:", kmeans_result$centers[i, "sex"], ", Body Mass:", kmeans_result$centers[i, "body_mass_g"], "\n")
}
# Print cluster means
for (i in 1:kmeans_result$centers+3) {
cat("Cluster", i-1, "-> Sex:", kmeans_result$centers[i, "sex"], ", Body Mass:", kmeans_result$centers[i, "body_mass_g"], "\n")
}
# Print cluster means
for (i in 1:nrow(kmeans_result$centers)) {
cat("Cluster", i - 1, "-> Sex:", kmeans_result$centers[i, "sex"], ", Body Mass:", kmeans_result$centers[i, "body_mass_g"], "\n")
}
set.seed(123)
df = df_scaled[c("sex","body_mass_g")]
# Using k-means
kmeans_result <- kmeans(df, centers = 4, nstart = 25)
# Ver los resultados
# Print cluster means
for (i in 1:nrow(kmeans_result$centers)) {
cat("Cluster", i - 1, "-> Sex:", kmeans_result$centers[i, "sex"], ", Body Mass:", kmeans_result$centers[i, "body_mass_g"], "\n")
}
# Visualización de clusters
fviz_cluster(kmeans_result,data=df, geom = "point", stand = FALSE, choose.vars = c("sex", "body_mass_g"))
# Ver los resultados
# Print cluster means
for (i in 1:nrow(kmeans_result$centers)) {
cat("Cluster", i - 1, "-> Sex:", kmeans_result$centers[i, "sex"], ", Body Mass:", kmeans_result$centers[i, "body_mass_g"], "\n")
}
